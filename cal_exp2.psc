Algoritmo Calculo_expresión
	Escribir "Calculo de la expresión:"
	Escribir "R=100-(-50X2) * 4"
	Escribir "Proceso:"
	Escribir "R=100-(-100) * 4"
	Escribir "R=100-(-400)"
	Escribir "R=100+400"
	Escribir "R=500"
	Escribir "Resoltado por la computadora, R=", 100-(-50*2) * 4
	Escribir "Fin"
FinAlgoritmo
